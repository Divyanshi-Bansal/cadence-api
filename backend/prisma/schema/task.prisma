model Task {
  id               String    @id @default(cuid())
  projectId        String
  stageId          String 
  issueTypeId      String
  parentTaskId     String?
  title            String
  description      Json?
  teamLabel        String?
  priority         Priority  @default(MEDIUM)
  reporterId       String
  dueDate          DateTime?
  estimatedMinutes Int?
  archivedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  project          Project        @relation(fields: [projectId], references: [id])
  stage            BoardStage     @relation(fields: [stageId], references: [id])
  issueType        IssueType      @relation(fields: [issueTypeId], references: [id])
  parent           Task?          @relation("Subtasks", fields: [parentTaskId], references: [id])
  subtasks         Task[]         @relation("Subtasks") @default([])
  reporter         User           @relation(fields: [reporterId], references: [id])
  assignees        TaskAssignee[] @default([])
  comments         Comment[]      @default([])

  @@index([projectId])
  @@index([stageId])
}

model TaskAssignee {
  id       String @id @default(cuid())
  taskId   String
  userId   String

  task     Task @relation(fields: [taskId], references: [id])
  user     User @relation(fields: [userId], references: [id])

  @@unique([taskId, userId])
}



